# Mainha Assistant backend
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# SuperVoz F5 API usada pelo orquestrador.
SUPERVOZ_API_URL=https://warllemedicao--supervoz-f5-gpu-fastapi-app.modal.run
SUPERVOZ_API_TOKEN=
SUPERVOZ_VOICE=warllem
SUPERVOZ_MODE=balanced
SUPERVOZ_NFE_STEP=32
SUPERVOZ_SPEED=1.0

# Token opcional para proteger chamadas da extensao/app ao orquestrador.
ASSISTANT_AUTH_TOKEN=

# Para desenvolvimento local com extensao Chrome.
CORS_ALLOW_ORIGINS=*
STT_PROVIDER=frontend
REQUEST_TIMEOUT_SECONDS=120
